# --- CONFIGURAÇÕES DO SERVIDOR ---
# Porta onde o servidor Express vai rodar (Ex: 3001)
PORT=3001

# --- API CHECKTUDO (PESQUISA DE PLACA) ---
# Usuário de acesso à API Checktudo
USERNAME_PESQUISA=
# URL de autenticação (Ex: https://api.checktudo.com.br/login)
URL_PESQUISA=
# URL base para consulta de veículos
API_CHECKTUDO=

# --- SERVIÇO DE E-MAIL (NODEMAILER) ---
# Endereço de e-mail usado para enviar os contratos
EMAIL_LOGIN=
# Senha do e-mail ou senha de aplicativo
EMAIL_PASSWORD=

# --- SEGURANÇA (GOOGLE RECAPTCHA) ---
# Chave secreta fornecida pelo Google Admin Console
GOOGLE_SECRET=